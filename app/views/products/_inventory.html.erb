<% if product.inventory_count? %>
  <p class="fw-bold text-success"><%= product.inventory_count %> in stock</p>
<% else %>
  <p class="text-danger fw-bold">Out of stock</p>
  <p class="text-muted">Email me when available.</p>

  <%= form_with model: [product, Subscriber.new], class: "mt-3 p-3 border rounded shadow-sm" do |form| %>
    <div class="mb-3">
      <%= form.email_field :email, class: "form-control", placeholder: "you@example.com", required: true %>
    </div>
    <%= form.submit "Notify Me", class: "btn btn-primary" %>
  <% end %>
<% end %>
